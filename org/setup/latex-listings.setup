#+LATEX_HEADER: \definecolor{mc@lstgitcmd}{HTML}{0000FF}      % Blue: git, cd, ls, ...
#+LATEX_HEADER: \definecolor{mc@lstgitsubcmd}{HTML}{008080}   % Teal: commit, log, merge, ...
