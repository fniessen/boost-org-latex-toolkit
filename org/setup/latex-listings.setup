#+LATEX_HEADER:     search-for-code,
#+LATEX_HEADER:     squash,
#+LATEX_HEADER:     st,
#+LATEX_HEADER:     stash-all,
#+LATEX_HEADER:     stash-only-untracked,
#+LATEX_HEADER:     % U
#+LATEX_HEADER:     unadd,
#+LATEX_HEADER:     uncommit,
#+LATEX_HEADER:     uncommit-unadd,
#+LATEX_HEADER:     uncommit-unstage,
#+LATEX_HEADER:     unmodify,
#+LATEX_HEADER:     unstage,
#+LATEX_HEADER:     upstream-commit,
#+LATEX_HEADER:     % W
#+LATEX_HEADER:     wdf,
#+LATEX_HEADER:     wdfc,
#+LATEX_HEADER:     whoami,
#+LATEX_HEADER:     wshow,
#+LATEX_HEADER:     wwflu
#+LATEX_HEADER:   },
#+LATEX_HEADER:   keywordstyle=[1]\color{mc@lstgitcmd}\bfseries,
#+LATEX_HEADER:   keywordstyle=[2]\color{mc@lstgitcmd}\bfseries,
#+LATEX_HEADER:   keywordstyle=[3]\color{mc@lstgitopt},
#+LATEX_HEADER:   keywordstyle=[4]\color{mc@lstgitref}\bfseries,
#+LATEX_HEADER:   keywordstyle=[5]\color{mc@lstgitshortopt}\bfseries,
#+LATEX_HEADER:   keywordstyle=[6]\color{mc@lstgboost}\bfseries,
#+LATEX_HEADER:   %
#+LATEX_HEADER:   % Treat lines starting with '#' as shell comments.
#+LATEX_HEADER:   morecomment=[l]{\#},
#+LATEX_HEADER:   %
#+LATEX_HEADER:   % Treat '.' and '/' as part of identifiers so compound Git names
#+LATEX_HEADER:   % such as feature/login and path-like references are highlighted
#+LATEX_HEADER:   % as single keywords.
#+LATEX_HEADER:   %
#+LATEX_HEADER:   % The '-' character is intentionally excluded. Including it in
#+LATEX_HEADER:   % alsoletter would cause options beginning with '-' (for example
#+LATEX_HEADER:   % -a, --all, --graph or --force-with-lease) to be parsed as part
#+LATEX_HEADER:   % of larger identifiers and prevent correct option highlighting.
#+LATEX_HEADER:   alsoletter={./},
#+LATEX_HEADER:   sensitive=true,
#+LATEX_HEADER: }
