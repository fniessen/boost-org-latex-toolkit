%% mcboxes.sty -- MCit box environments

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mcboxes}[2026/07/18 v1.0 Mission Critical boxes]

\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}

% Shared box style
\tcbset{
  mcmessagebox/.style={
    enhanced,
    fontupper=\sffamily,
    left=10mm
  }
}

% Info
\definecolor{mcinfobg}{HTML}{BDE5F8}
\definecolor{mcinfofg}{HTML}{00529B}

\newtcolorbox{info}{
  mcmessagebox,
  colback=mcinfobg,
  coltext=mcinfofg,
  colframe=mcinfofg,
  % overlay={%
  %   \node at ([xshift=5mm]frame.west)
  %   {\includegraphics[width=7mm,height=7mm]{info}};}
}

% Tip
