%% boostboxes.sty

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{boostboxes}[2026/07/18 v1.2 Read the Docs-style boxes]

\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}

% ---------------------------------------------------------------------------
% Colors from the Read the Docs theme
% ---------------------------------------------------------------------------

% Blue: note, seealso, admonition, info
\definecolor{boostbluetitle}{HTML}{6AB0DE}
\definecolor{boostblueback}{HTML}{E7F2FA}

% Green: tip, hint, important
\definecolor{boostgreentitle}{HTML}{1ABC9C}
\definecolor{boostgreenback}{HTML}{DBFAF4}

% Orange: warning, attention, caution
\definecolor{boostorangetitle}{HTML}{F0B37E}
\definecolor{boostorangeback}{HTML}{FFEDCC}

% Red: danger, error
\definecolor{boostredtitle}{HTML}{F29F97}
\definecolor{boostredback}{HTML}{FDF3F2}

% Inline tasks
\definecolor{boosttodotitle}{HTML}{FFE55A}
\definecolor{boosttodoback}{HTML}{FFF8CC}

% Body text
\definecolor{boostboxtext}{HTML}{404040}

% ---------------------------------------------------------------------------
% Admonition icon
% ---------------------------------------------------------------------------

% TODO: Raise icon of -0.15ex?
\newcommand{\boostboxicon}[1]{%
  \tikz[baseline=(icon.base)]{
    \node[
      circle,
      fill=white,
      text=#1,
      font=\sffamily\bfseries\tiny,
      inner sep=0.35ex,
    ] (icon) {!};
  }%
}

% ---------------------------------------------------------------------------
% Shared style
% ---------------------------------------------------------------------------

\tcbset{
  boostbox/.style={
    enhanced,
    frame hidden,
    boxrule=0pt,
    arc=0pt,
    outer arc=0pt,
    sharp corners,
    fontupper=\sffamily,
    fonttitle=\sffamily\bfseries,
    coltext=boostboxtext,
    coltitle=white,
    left=2mm,
    right=2mm,
    top=3.5mm,
    bottom=3.5mm,
    lefttitle=2mm,
    righttitle=2mm,
    toptitle=1mm,
    bottomtitle=1mm,
    before skip=1em,
    after skip=1em,
  }
}

% ---------------------------------------------------------------------------
% Environment declaration
%
% \DeclareBoostBox
%   {environment name}
%   {displayed title}
%   {title color}
%   {background color}
% ---------------------------------------------------------------------------

\newcommand{\DeclareBoostBox}[4]{%
  \newtcolorbox{#1}[1][]{%
    boostbox,
    colback=#4,
    colbacktitle=#3,
    title={%
      \boostboxicon{#3}%
      \hspace{0.6em}%
      #2%
    },
    ##1
  }%
}

% ---------------------------------------------------------------------------
% Blue admonitions
% ---------------------------------------------------------------------------

\DeclareBoostBox
  {note}
  {Note}
  {boostbluetitle}
  {boostblueback}

\DeclareBoostBox
  {seealso}
  {See also}
  {boostbluetitle}
  {boostblueback}

% Kept for compatibility with the original package.
\DeclareBoostBox
  {info}
  {Info}
  {boostbluetitle}
  {boostblueback}

% Generic admonition with a user-provided title:
%
% \begin{admonition}{Custom title}
%   ...
% \end{admonition}
%
% Optional tcolorbox settings may precede the title:
%
% \begin{admonition}[breakable]{Custom title}
%   ...
% \end{admonition}

\newtcolorbox{admonition}[2][]{%
  boostbox,
  colback=boostblueback,
  colbacktitle=boostbluetitle,
  title={%
    \boostboxicon{boostbluetitle}%
    \hspace{0.6em}%
    #2%
  },
  #1
}

% ---------------------------------------------------------------------------
% Green admonitions
% ---------------------------------------------------------------------------

\DeclareBoostBox
  {tip}
  {Tip}
  {boostgreentitle}
  {boostgreenback}

\DeclareBoostBox
  {hint}
  {Hint}
  {boostgreentitle}
  {boostgreenback}

\DeclareBoostBox
  {important}
  {Important}
  {boostgreentitle}
  {boostgreenback}

% ---------------------------------------------------------------------------
% Orange admonitions
% ---------------------------------------------------------------------------

\DeclareBoostBox
  {warning}
  {Warning}
  {boostorangetitle}
  {boostorangeback}

\DeclareBoostBox
  {attention}
  {Attention}
  {boostorangetitle}
  {boostorangeback}

\DeclareBoostBox
  {caution}
  {Caution}
  {boostorangetitle}
  {boostorangeback}

% ---------------------------------------------------------------------------
% Red admonitions
% ---------------------------------------------------------------------------

\DeclareBoostBox
  {danger}
  {Danger}
  {boostredtitle}
  {boostredback}

\DeclareBoostBox
  {error}
  {Error}
  {boostredtitle}
  {boostredback}

% ---------------------------------------------------------------------------
% Inline tasks
% ---------------------------------------------------------------------------

\NewTColorBox{boostinlinetask}{O{TODO} m O{}}{%
  enhanced,
  frame hidden,
  boxrule=0pt,
  sharp corners,
  colback=boosttodoback,
  colbacktitle=boosttodotitle,
  coltitle=black,
  coltext=boostboxtext,
  fonttitle=\sffamily,
  fontupper=\sffamily,
  left=2mm,
  right=2mm,
  top=2.5mm,
  bottom=2.5mm,
  lefttitle=2mm,
  righttitle=2mm,
  toptitle=0.7mm,
  bottomtitle=0.7mm,
  before skip=0.8em,
  after skip=0.8em,
  title={%
    \textbf{#1}%
    \hspace{0.35em}%
    #2%
    \if\relax\detokenize{#3}\relax
    \else
      \hfill\texttt{\small:#3:}%
    \fi
  },
}

\NewDocumentCommand{\boostcompacttask}{O{TODO} m O{}}{%
  \begin{tcolorbox}[
    enhanced,
    frame hidden,
    boxrule=0pt,
    sharp corners,
    colback=boosttodotitle,
    coltext=black,
    fontupper=\sffamily,
    left=2mm,
    right=2mm,
    top=0.7mm,
    bottom=0.7mm,
    before skip=0.8em,
    after skip=0.8em,
  ]
    \textbf{#1}%
    \hspace{0.35em}%
    #2%
    \if\relax\detokenize{#3}\relax
    \else
      \hfill\texttt{\small:#3:}%
    \fi
  \end{tcolorbox}%
}

\endinput
