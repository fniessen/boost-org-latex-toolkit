%% boostboxes.sty

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{boostboxes}[2026/07/18 v1.1 Read the Docs-style boxes]

\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}

% ---------------------------------------------------------------------------
% Colours
% ---------------------------------------------------------------------------

% Note / Info
\definecolor{boostnotetitle}{HTML}{6AB0DE}
\definecolor{boostnoteback}{HTML}{E7F2FA}

% Tip
\definecolor{boosttiptitle}{HTML}{1ABC9C}
\definecolor{boosttipback}{HTML}{DBFAF4}

% Warning
\definecolor{boostwarningtitle}{HTML}{F0B37E}
\definecolor{boostwarningback}{HTML}{FFEDCC}

% Error
\definecolor{boosterrortitle}{HTML}{F29F97}
\definecolor{boosterrorback}{HTML}{FCE8E6}

% Body text
\definecolor{boostboxtext}{HTML}{202020}

% ---------------------------------------------------------------------------
% Icon
% ---------------------------------------------------------------------------

\newcommand{\boostboxicon}[1]{%
  \raisebox{-0.15ex}{%
    \tikz[baseline=(boosticon.base)]{
      \node[
        circle,
        fill=white,
        text=#1,
        font=\sffamily\bfseries\scriptsize,
        inner sep=0pt,
        minimum size=2.8ex
      ] (boosticon) {!};
    }%
  }%
}

% ---------------------------------------------------------------------------
% Shared style
% ---------------------------------------------------------------------------

\tcbset{
  boostbox/.style={
    enhanced,
    frame hidden,
    boxrule=0pt,
    arc=0pt,
    outer arc=0pt,
    titlerule=0pt,
    sharp corners,
    fontupper=\sffamily,
    fonttitle=\sffamily\bfseries,
    coltext=boostboxtext,
    coltitle=white,
    left=4mm,
    right=4mm,
    top=3.5mm,
    bottom=3.5mm,
    lefttitle=4mm,
    righttitle=4mm,
    toptitle=1.8mm,
    bottomtitle=1.8mm,
    before skip=1em,
    after skip=1em,
  }
}

% ---------------------------------------------------------------------------
% Environments
% ---------------------------------------------------------------------------

\newtcolorbox{note}[1][]{
  boostbox,
  colback=boostnoteback,
  colbacktitle=boostnotetitle,
  title={\boostboxicon{boostnotetitle}\hspace{0.6em}Note},
  #1
}

\newtcolorbox{info}[1][]{
  boostbox,
  colback=boostnoteback,
  colbacktitle=boostnotetitle,
  title={\boostboxicon{boostnotetitle}\hspace{0.6em}Info},
  #1
}

\newtcolorbox{tip}[1][]{
  boostbox,
  colback=boosttipback,
  colbacktitle=boosttiptitle,
  title={\boostboxicon{boosttiptitle}\hspace{0.6em}Tip},
  #1
}

\newtcolorbox{warning}[1][]{
  boostbox,
  colback=boostwarningback,
  colbacktitle=boostwarningtitle,
  title={\boostboxicon{boostwarningtitle}\hspace{0.6em}Warning},
  #1
}

\newtcolorbox{error}[1][]{
  boostbox,
  colback=boosterrorback,
  colbacktitle=boosterrortitle,
  title={\boostboxicon{boosterrortitle}\hspace{0.6em}Error},
  #1
}

\endinput
